# Пример файла `.env`
# Именно в данный файл выносятся все секреты из docker-compose.yml и других файлов
# Следить, чтобы данный файл (`.env`) был прописан в `.gitignore`

# =========== для postgres ===========
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_postgres_database_name

# =========== для MinIO ===========
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_minio_password
MINIO_BROWSER=on
MINIO_IDENTITY_OPENID_ENABLE=off
MINIO_CALLHOME_ENABLE=off

# =========== для airflow ===========
AIRFLOW__WEBSERVER__SECRET_KEY=your_airflow_secret_key
AIRFLOW_USER=your_airflow_user
AIRFLOW_USER_FIRSTNAME=your_airflow_firstname
AIRFLOW_USER_LASTNAME=your_airflow_lastname
AIRFLOW_PASSWORD=your_airflow_password